interface DataContext {
  key: string;
  value: any;
  description?: string;
}

function isValid(context: DataContext): context is DataContext {
  return (
    context !== null &&
    typeof context === 'object' &&
    typeof context.key === 'string' &&
    context.description !== undefined &&
    (typeof context.description === 'string' || context.description === undefined)
  );
}

export default {
  async mounted(el: any, binding: { value: DataContext, instance: any }) {
    const store = binding.instance.$store;
    const context = binding.value;

    if (binding.instance && binding.instance[context.key]) {
      if(!isValid(context)) {
        throw new Error('Invalid ui-context value');
      }

      el._uiContextId = await store.dispatch('ui-context/add', { ...context, value: binding.instance[context.key] });
    }
  },

  async beforeUnmount(el: any, binding: { value: DataContext, instance: any }) {
    const store = binding.instance.$store;


    console.log(store.getters['ui-context/all']());

    await store.dispatch('ui-context/remove', el._uiContextId);
  }
};
